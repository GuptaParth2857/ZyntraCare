// Prisma Schema — ZyntraCare (PostgreSQL)
// Use this for production deployment

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USER & AUTH ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?   @unique
  passwordHash  String?
  avatar        String?
  city          String?
  age           Int?
  bloodGroup    String?
  conditions    String?
  role          String    @default("patient")
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  subscription     Subscription?
  appointments    Appointment[]
  healthRecords   HealthRecord[]
  prescriptions   Prescription[]
  otpTokens       OtpToken[]
  sessions        UserSession[]
  healthMetrics  HealthMetric[]
  favorites      FavoriteHospital[]
  notifications  Notification[]
}

model OtpToken {
  id        String   @id @default(cuid())
  userId    String?
  phone     String
  otp       String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  device    String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── SUBSCRIPTIONS ─────────────────────────────────────────

model Subscription {
  id         String    @id @default(cuid())
  userId     String    @unique
  plan       String    @default("free")
  status     String    @default("active")
  startDate  DateTime  @default(now())
  endDate    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── HOSPITALS ─────────────────────────────────────────────

model Hospital {
  id           String   @id @default(cuid())
  name         String
  address      String
  city         String
  state        String
  pincode      String   @default("")
  phone        String
  email        String   @default("")
  website      String   @default("")
  specialties  String
  beds         String
  emergency    Boolean  @default(false)
  lat          Float
  lng          Float
  rating       Float    @default(0)
  image        String   @default("")
  workingHours String   @default("24/7")
  doctors      Int      @default(0)
  verified     Boolean  @default(false)
  source       String   @default("manual")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appointments  Appointment[]
  favorites    FavoriteHospital[]
}

model FavoriteHospital {
  id         String @id @default(cuid())
  userId     String
  hospitalId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hospital Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@unique([userId, hospitalId])
}

// ─── APPOINTMENTS ──────────────────────────────────────────

model Appointment {
  id           String   @id @default(cuid())
  userId       String
  hospitalId   String?
  doctorName   String
  specialty    String
  date         String
  time         String
  status       String   @default("pending")
  notes        String   @default("")
  fee          Float    @default(0)
  isOnline     Boolean  @default(false)
  meetingLink  String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hospital Hospital? @relation(fields: [hospitalId], references: [id])
}

// ─── HEALTH RECORDS ────────────────────────────────────────

model HealthRecord {
  id         String   @id @default(cuid())
  userId     String
  title      String
  type       String
  fileUrl    String   @default("")
  notes      String   @default("")
  date       String
  hospital   String   @default("")
  doctor     String   @default("")
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Prescription {
  id           String   @id @default(cuid())
  userId       String
  doctorName   String
  medicines    String
  instructions String   @default("")
  date         String
  validUntil   String   @default("")
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── HEALTH METRICS ────────────────────────────────────────

model HealthMetric {
  id            String   @id @default(cuid())
  userId        String
  date          String
  bloodPressure String   @default("")
  heartRate     Int?
  bloodSugar    Float?
  weight        Float?
  height        Float?
  temperature   Float?
  oxygenLevel   Float?
  notes         String   @default("")
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── NOTIFICATIONS ─────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  read      Boolean  @default(false)
  link      String   @default("")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── AMBULANCE SYSTEM ──────────────────────────────────────

model Ambulance {
  id              String   @id @default(cuid())
  driverName      String?
  vehicleNumber   String   @unique
  phone           String   @unique
  lat             Float?
  lng             Float?
  isAvailable     Boolean  @default(true)
  type            String   @default("basic")
  hospitalId      String?  
  email           String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings        AmbulanceBooking[]
}

model AmbulanceBooking {
  id            String   @id @default(cuid())
  userId        String?
  ambulanceId   String?
  patientName   String
  patientPhone  String
  pickupLat     Float
  pickupLng     Float
  pickupAddress String
  dropLat       Float?
  dropLng       Float?
  dropAddress   String?
  status        String   @default("pending")
  assignedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  ambulance Ambulance? @relation(fields: [ambulanceId], references: [id], onDelete: SetNull)
}