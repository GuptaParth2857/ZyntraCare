# =============================================================================
# ZyntraCare Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Database (SQLite for local, PostgreSQL for production)
# -----------------------------------------------------------------------------
DATABASE_URL="file:./dev.db"

# For PostgreSQL (Neon, Supabase, RDS):
# DATABASE_URL="postgresql://user:password@host:5432/dbname"

# -----------------------------------------------------------------------------
# Authentication (NextAuth)
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# For production:
# NEXTAUTH_URL="https://your-domain.com"

# OAuth Providers (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# AI Integration (Google Gemini)
# -----------------------------------------------------------------------------
GEMINI_API_KEY="your-gemini-api-key"

# -----------------------------------------------------------------------------
# Email (Nodemailer)
# -----------------------------------------------------------------------------
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-app-password"
EMAIL_FROM="ZyntraCare <noreply@zyntracare.com>"

# -----------------------------------------------------------------------------
# SMS (Twilio - optional)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# -----------------------------------------------------------------------------
# Supabase (optional - for real-time)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# -----------------------------------------------------------------------------
# Map Tiles (for offline use)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MAP_TILES_URL="https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png"

# -----------------------------------------------------------------------------
# External APIs
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=""

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_TRACKING_ID=""

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_IOT_SIMULATION="true"
NEXT_PUBLIC_ENABLE_BLOCKCHAIN="true"